__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# Data caches and downloads
data/
/tmp/
outputs/
!outputs/
outputs/*
!outputs/vBTC_final_simulation/
!outputs/vBTC_final_simulation/*.csv

# Trained model artifacts (regenerated via live/train_v6_clean_artifact.py).
# Selected deployment artifacts are kept tracked so a fresh git clone is enough
# to reproduce the documented deployment/research state.
# Note: must use `models/*` (exclude contents) not `models/` (exclude dir),
# otherwise the `!` exceptions below cannot re-include files.
models/*
!models/v6_clean_ensemble.pkl
!models/v6_clean_meta.json
!models/v6_clean_h*_ensemble.pkl
!models/v6_clean_h*_meta.json
!models/v7_xyz_ensemble.pkl
!models/v7_xyz_meta.json
!models/vBTC_production.pkl
!models/vBTC_production.json

# Live paper-trade runtime state
live/state/

# Claude Code local settings
.claude/

# Editor / OS
.vscode/
.idea/
.DS_Store

# Local env
.env
.env.local

# Live model artifacts: ignore all EXCEPT the two-book production models (~44MB, published via git so
# the live server pulls fresh models each month). Use `live/models/*` (contents) not `live/models/` (dir),
# else the `!` re-includes below can't take effect. Other ~940MB old vBTC/convexity .pkl stay local.
live/models/*
!live/models/twobook_flow_models.pkl
!live/models/twobook_price_models.pkl
